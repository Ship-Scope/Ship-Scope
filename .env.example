# ===========================================
# ShipScope Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ----- Database -----
DATABASE_URL=postgresql://shipscope:shipscope@localhost:5432/shipscope

# ----- Redis -----
REDIS_URL=redis://localhost:6379

# ----- AI Provider (at least one required) -----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ----- AI Model Selection -----
# Options: gpt-4o, gpt-4o-mini, claude-sonnet-4-20250514, claude-haiku
AI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ----- Server -----
PORT=4000
WEB_PORT=3000
NODE_ENV=development

# ----- Auth (optional, for cloud version) -----
JWT_SECRET=change-me-to-a-random-string

# ----- Demo Mode -----
# Set to true to run in read-only demo mode with sample data
DEMO_MODE=false

# ----- Self-Hosting -----
# Set to your domain when deploying
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
