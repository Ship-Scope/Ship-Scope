generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ============================================
// FEEDBACK INGESTION
// ============================================

model FeedbackSource {
  id        String   @id @default(cuid())
  name      String
  type      String   // csv, json, api, webhook, manual
  filename  String?
  rowCount  Int      @default(0)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedbackItems FeedbackItem[]
}

model FeedbackItem {
  id        String   @id @default(cuid())
  content   String   @db.Text
  sourceId  String
  source    FeedbackSource @relation(fields: [sourceId], references: [id])

  // Metadata
  author    String?
  email     String?
  channel   String?  // support_ticket, interview, survey, slack, app_review, manual, other
  metadata  Json     @default("{}")

  // AI Processing
  sentiment   Float?
  urgency     Float?
  embedding   Unsupported("vector(1536)")?
  embeddedAt  DateTime?
  processedAt DateTime?

  // Relations
  themes    FeedbackThemeLink[]
  proposals ProposalEvidence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceId])
  @@index([channel])
  @@index([createdAt])
  @@index([processedAt])
  @@index([sentiment])
  @@index([urgency])
}

// ============================================
// AI SYNTHESIS
// ============================================

model Theme {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  category    String?  // bug, feature_request, ux_issue, performance

  // Scoring
  painPoints       String[]
  feedbackCount    Int    @default(0)
  avgSentiment     Float  @default(0)
  avgUrgency       Float  @default(0)
  opportunityScore Float  @default(0)

  // Relations
  feedbackItems FeedbackThemeLink[]
  proposals     Proposal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([opportunityScore])
}

model FeedbackThemeLink {
  id              String       @id @default(cuid())
  feedbackItemId  String
  themeId         String
  similarityScore Float        @default(1.0)
  feedbackItem    FeedbackItem @relation(fields: [feedbackItemId], references: [id])
  theme           Theme        @relation(fields: [themeId], references: [id])

  @@unique([feedbackItemId, themeId])
}

// ============================================
// FEATURE PROPOSALS
// ============================================

model Proposal {
  id          String  @id @default(cuid())
  title       String
  problem     String  @db.Text
  solution    String  @db.Text

  // RICE Scoring
  reachScore      Int?
  impactScore     Int?
  confidenceScore Int?
  effortScore     Int?
  riceScore       Float?

  // Status
  status      String  @default("proposed") // proposed, approved, rejected, shipped

  // Relations
  themeId     String?
  theme       Theme?  @relation(fields: [themeId], references: [id])
  evidence    ProposalEvidence[]
  specs       Spec[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([riceScore])
}

model ProposalEvidence {
  id              String       @id @default(cuid())
  proposalId      String
  feedbackItemId  String
  relevanceScore  Float        @default(1.0)
  quote           String?      @db.Text
  proposal        Proposal     @relation(fields: [proposalId], references: [id])
  feedbackItem    FeedbackItem @relation(fields: [feedbackItemId], references: [id])

  @@unique([proposalId, feedbackItemId])
}

// ============================================
// SPEC GENERATION
// ============================================

model Spec {
  id          String   @id @default(cuid())
  proposalId  String   @unique
  proposal    Proposal @relation(fields: [proposalId], references: [id])

  // Generated content
  prdMarkdown  String?  @db.Text
  agentPrompt  String?  @db.Text
  version      Int      @default(1)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================
// API KEYS (Webhook Authentication)
// ============================================

model ApiKey {
  id          String   @id @default(cuid())
  name        String   @default("Default")
  keyHash     String   @unique
  keyPrefix   String
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  isActive    Boolean  @default(true)

  @@index([keyHash])
}
