generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-arm64-openssl-1.1.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ============================================
// FEEDBACK INGESTION
// ============================================

model FeedbackSource {
  id        String   @id @default(cuid())
  name      String
  type      String   // csv, json, api, webhook, manual
  filename  String?
  rowCount  Int      @default(0)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedbackItems FeedbackItem[]
}

model FeedbackItem {
  id        String   @id @default(cuid())
  content   String   @db.Text
  sourceId  String
  source    FeedbackSource @relation(fields: [sourceId], references: [id])

  // Metadata
  author    String?
  email     String?
  channel   String?  // support_ticket, interview, survey, slack, app_review, manual, other
  metadata  Json     @default("{}")

  // AI Processing
  sentiment   Float?
  urgency     Float?
  embedding   Unsupported("vector(1536)")?
  embeddedAt  DateTime?
  processedAt DateTime?

  // Relations
  themes    FeedbackThemeLink[]
  proposals ProposalEvidence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceId])
  @@index([channel])
  @@index([createdAt])
  @@index([processedAt])
  @@index([sentiment])
  @@index([urgency])
}

// ============================================
// AI SYNTHESIS
// ============================================

model Theme {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  category    String?  // bug, feature_request, ux_issue, performance

  // Scoring
  painPoints       String[]
  feedbackCount    Int    @default(0)
  avgSentiment     Float  @default(0)
  avgUrgency       Float  @default(0)
  opportunityScore Float  @default(0)

  // Jira Integration
  jiraEpicKey  String?  // e.g. "PROJ-100" — linked Jira Epic
  jiraEpicUrl  String?  // Full URL to the Jira Epic

  // Trello Integration
  trelloBoardListId String?  // Trello list ID where theme cards are created
  trelloBoardListUrl String? // URL to the Trello board

  // Linear Integration
  linearProjectId   String?  // Linear project ID where theme issues are grouped
  linearProjectUrl  String?  // Full URL to the Linear project

  // Relations
  feedbackItems FeedbackThemeLink[]
  proposals     Proposal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([opportunityScore])
}

model FeedbackThemeLink {
  id              String       @id @default(cuid())
  feedbackItemId  String
  themeId         String
  similarityScore Float        @default(1.0)
  feedbackItem    FeedbackItem @relation(fields: [feedbackItemId], references: [id])
  theme           Theme        @relation(fields: [themeId], references: [id])

  @@unique([feedbackItemId, themeId])
}

// ============================================
// FEATURE PROPOSALS
// ============================================

model Proposal {
  id          String  @id @default(cuid())
  title       String
  problem     String  @db.Text
  solution    String  @db.Text

  // RICE Scoring
  reachScore      Int?
  impactScore     Int?
  confidenceScore Int?
  effortScore     Int?
  riceScore       Float?

  // Status
  status      String  @default("proposed") // proposed, approved, rejected, shipped

  // Relations
  themeId     String?
  theme       Theme?  @relation(fields: [themeId], references: [id])
  evidence    ProposalEvidence[]
  specs       Spec[]
  jiraIssue    JiraIssue?
  trelloCard   TrelloCard?
  linearIssue  LinearIssue?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([riceScore])
}

model ProposalEvidence {
  id              String       @id @default(cuid())
  proposalId      String
  feedbackItemId  String
  relevanceScore  Float        @default(1.0)
  quote           String?      @db.Text
  proposal        Proposal     @relation(fields: [proposalId], references: [id])
  feedbackItem    FeedbackItem @relation(fields: [feedbackItemId], references: [id])

  @@unique([proposalId, feedbackItemId])
}

// ============================================
// SPEC GENERATION
// ============================================

model Spec {
  id          String   @id @default(cuid())
  proposalId  String   @unique
  proposal    Proposal @relation(fields: [proposalId], references: [id])

  // Generated content
  prdMarkdown  String?  @db.Text
  agentPrompt  String?  @db.Text
  version      Int      @default(1)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================
// API KEYS (Webhook Authentication)
// ============================================

model ApiKey {
  id          String   @id @default(cuid())
  name        String   @default("Default")
  keyHash     String   @unique
  keyPrefix   String
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  isActive    Boolean  @default(true)

  @@index([keyHash])
}

// ============================================
// ACTIVITY LOG
// ============================================

model ActivityLog {
  id          String   @id @default(cuid())
  type        String   // 'import', 'synthesis', 'proposal_generation', 'spec_generation'
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@map("activity_log")
}

// ============================================
// SETTINGS (Key-Value Store)
// ============================================

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ============================================
// JIRA INTEGRATION
// ============================================

model JiraIssue {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id])

  // Jira issue data
  jiraKey     String   // e.g. "PROJ-123"
  jiraId      String   // Jira internal ID
  jiraUrl     String   // Full URL to the issue
  issueType   String   @default("Story") // Story, Task, Bug, Epic
  status      String   @default("To Do") // Jira workflow status
  summary     String
  epicKey     String?  // Parent epic key if created via theme export
  syncedAt    DateTime @default(now())

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([proposalId])
  @@unique([jiraKey])
  @@index([proposalId])
  @@index([epicKey])
  @@map("jira_issues")
}

// ============================================
// TRELLO INTEGRATION
// ============================================

model TrelloCard {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id])

  // Trello card data
  cardId      String   // Trello card ID
  cardUrl     String   // Full URL to the card
  listName    String   @default("To Do") // Current list name (acts as status)
  cardName    String   // Card title
  boardId     String   // Board the card belongs to
  syncedAt    DateTime @default(now())

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([proposalId])
  @@unique([cardId])
  @@index([proposalId])
  @@index([boardId])
  @@map("trello_cards")
}

// ============================================
// LINEAR INTEGRATION
// ============================================

model LinearIssue {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id])

  // Linear issue data
  linearId       String   // Linear internal UUID
  identifier     String   // e.g. "ENG-123"
  linearUrl      String   // Full URL to the issue
  teamId         String   // Linear team ID
  status         String   @default("Backlog")
  priority       Int      @default(0) // 0=No priority, 1=Urgent, 2=High, 3=Medium, 4=Low
  issueTitle     String
  projectId      String?  // Linear project ID (for theme exports)
  projectName    String?  // Linear project name
  labelIds       String[] // Applied label IDs
  cycleId        String?  // Sprint/cycle assignment
  estimate       Int?     // Story point estimate
  syncedAt       DateTime @default(now())

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([proposalId])
  @@unique([linearId])
  @@unique([identifier])
  @@index([proposalId])
  @@index([teamId])
  @@index([projectId])
  @@map("linear_issues")
}
